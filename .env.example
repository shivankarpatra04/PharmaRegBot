# ============================================================
# PharmaRegBot — Environment Configuration
# Copy this file to ".env" and fill in your real values.
# NEVER commit your real .env file.
# ============================================================

# --- API keys (only the providers you use are required) ---
NVIDIA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Generation (chat) provider: "nvidia" | "openai" | "anthropic" ---
LLM_PROVIDER=nvidia
# Model must match the provider. NVIDIA examples:
#   meta/llama-3.3-70b-instruct, meta/llama-3.1-8b-instruct,
#   nvidia/llama-3.1-nemotron-70b-instruct, mistralai/mixtral-8x7b-instruct-v0.1
LLM_MODEL=meta/llama-3.3-70b-instruct

# --- Embedding provider: "nvidia" | "openai" ---
EMBEDDING_PROVIDER=nvidia
# NVIDIA embedding model (8192-token context, supports query/passage input types).
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
# OpenAI embedding model (used only when EMBEDDING_PROVIDER=openai).
EMBEDDING_MODEL=text-embedding-3-small

# --- NVIDIA endpoint (OpenAI-compatible; rarely needs changing) ---
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Storage paths ---
CHROMA_DB_PATH=./chroma_db
DOCUMENTS_PATH=./data/documents

# --- Supabase (user accounts / authentication) ---
# From Supabase → Project Settings → API. Use the service_role key (secret).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_service_role_key_here
SUPABASE_USERS_TABLE=users

# --- Retrieval ---
SIMILARITY_THRESHOLD=0.4

# --- Hindi response behaviour ---
# "translate" -> generate answer in English, then translate to Hindi (default, per spec)
# "native"    -> ask the LLM to answer directly in Hindi using the Hindi system prompt
HINDI_RESPONSE_MODE=translate
