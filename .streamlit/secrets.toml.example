# ============================================================
# PharmaRegBot — Streamlit Community Cloud secrets template
# ------------------------------------------------------------
# DO NOT commit a real secrets.toml (it is git-ignored).
#
# On Streamlit Community Cloud you do NOT upload this file.
# Instead, open your app →  ⋮  → "Settings" → "Secrets" and
# paste the key = "value" lines below (filling in real values).
#
# Streamlit Cloud exposes these to the app BOTH as st.secrets
# AND as environment variables, so the existing os.getenv()
# based config (src/utils/config.py) picks them up unchanged.
# ============================================================

# --- API keys (only the providers you actually use are required) ---
NVIDIA_API_KEY = ""
OPENAI_API_KEY = ""
ANTHROPIC_API_KEY = ""

# --- Generation (chat) provider: "nvidia" | "openai" | "anthropic" ---
LLM_PROVIDER = "nvidia"
LLM_MODEL = "meta/llama-3.3-70b-instruct"

# --- Embedding provider: "nvidia" | "openai" ---
EMBEDDING_PROVIDER = "nvidia"
NVIDIA_EMBEDDING_MODEL = "nvidia/llama-nemotron-embed-1b-v2"
EMBEDDING_MODEL = "text-embedding-3-small"

# --- NVIDIA endpoint (OpenAI-compatible; rarely needs changing) ---
NVIDIA_BASE_URL = "https://integrate.api.nvidia.com/v1"

# --- Storage paths ---
# NOTE: Streamlit Cloud's filesystem is EPHEMERAL — these dirs reset on
# every restart/redeploy. Uploaded documents and the vector index will
# need to be re-created after a restart. This is expected on the free tier.
CHROMA_DB_PATH = "./chroma_db"
DOCUMENTS_PATH = "./data/documents"

# --- Supabase (user accounts / authentication) ---
SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_KEY = "your_service_role_key_here"
SUPABASE_USERS_TABLE = "users"

# --- Retrieval ---
SIMILARITY_THRESHOLD = "0.4"

# --- Hindi response behaviour: "translate" | "native" ---
HINDI_RESPONSE_MODE = "translate"
